# =============================================================================
# APAD Frontend — copy to .env and adjust
# =============================================================================

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Show POC badge when OTP is displayed on screen (matches backend OTP_SHOW_ON_SCREEN)
VITE_POC_MODE=true

# App title shown in navbar
VITE_APP_NAME=APAD
