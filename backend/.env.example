# =============================================================================
# APAD Backend — copy to .env and adjust
# =============================================================================

# App
APP_NAME=APAD
DEBUG=true
API_PREFIX=/api

# Database
# Local SQLite:
#   DATABASE_URL=sqlite:///./apad.db
# Neon / PostgreSQL (paste from Neon dashboard — use pooled connection string):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Connection pool (PostgreSQL only; ignored for SQLite)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Security
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — comma-separated origins (must include your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public URLs (used in token links and OG tags)
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000

# OTP / SMS
# mock = on-screen OTP for local dev | twilio = real SMS via Twilio Verify
SMS_PROVIDER=mock
OTP_SIMULATION_MODE=true
OTP_SHOW_ON_SCREEN=true
POC_SMS_PREVIEW_PANEL=true
OTP_TTL_SECONDS=300
OTP_LENGTH=6
AD_COMPLETION_TTL_MINUTES=15
MIN_WATCH_SECONDS=5

# Default region when parsing numbers without a country code (ISO 3166-1 alpha-2)
DEFAULT_PHONE_REGION=IN

# Optional: seed demo admin, campaign, and test user on startup
SEED_DEMO_DATA=true
ADMIN_MOBILE=9999999999
ADMIN_PASSWORD=admin123

# Paid SMS (leave empty for mock mode)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=dlt
# Twilio Verify (required when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_OTP_CHANNEL=sms
# Twilio Programmable SMS — login link with offer URL (required for real login-link SMS)
TWILIO_FROM_NUMBER=

# Login offer SMS (sent on POST /api/login)
LOGIN_LINK_SMS_ENABLED=true
LOGIN_LINK_MESSAGE_TEMPLATE=Hi {user_name}, {promo}. Tap to view your offer: {link}
